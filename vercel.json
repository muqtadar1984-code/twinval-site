{
  "redirects": [
    {
      "source": "/reit",
      "destination": "https://app.twinval.com",
      "permanent": false
    },
    {
      "source": "/individual",
      "destination": "https://app.twinval.com/individual",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/entry",        "destination": "https://twinval-entry.vercel.app/entry" },
    { "source": "/entry/:path*", "destination": "https://twinval-entry.vercel.app/entry/:path*" }
  ]
}
